<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1B1F5E">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="İstatistikler"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#ffffff"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Öğrenme performansın"
                android:textSize="12sp"
                android:textColor="#8899cc"
                android:layout_marginBottom="20dp"/>

            <!-- XP ve Streak yan yana -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card_light"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOPLAM XP"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="#8899cc"/>

                    <TextView
                        android:id="@+id/tv_total_xp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 XP"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#B794D6"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_light"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GÜNLÜK SERİ"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="#8899cc"/>

                    <TextView
                        android:id="@+id/tv_daily_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 gün"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#B794D6"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Başarı Oranı -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="@drawable/bg_card_light"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BAŞARI ORANI"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="#8899cc"/>

                <TextView
                    android:id="@+id/tv_success_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="%0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#B794D6"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- Doğru ve Yanlış yan yana -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card_light"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOĞRU"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="#8899cc"/>

                    <TextView
                        android:id="@+id/tv_total_correct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#7DD4A0"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_light"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YANLIŞ"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="#8899cc"/>

                    <TextView
                        android:id="@+id/tv_total_wrong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#E07878"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Haftalık Aktivite -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_light"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Haftalık Aktivite"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2D1B69"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:gravity="center_horizontal">
                        <FrameLayout android:layout_width="12dp" android:layout_height="match_parent">
                            <View android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="@drawable/bg_bar_track"/>
                            <View android:id="@+id/bar1" android:layout_width="match_parent" android:layout_height="4dp"
                                android:background="@drawable/bg_bar_fill" android:layout_gravity="bottom"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:gravity="center_horizontal">
                        <FrameLayout android:layout_width="12dp" android:layout_height="match_parent">
                            <View android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="@drawable/bg_bar_track"/>
                            <View android:id="@+id/bar2" android:layout_width="match_parent" android:layout_height="4dp"
                                android:background="@drawable/bg_bar_fill" android:layout_gravity="bottom"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:gravity="center_horizontal">
                        <FrameLayout android:layout_width="12dp" android:layout_height="match_parent">
                            <View android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="@drawable/bg_bar_track"/>
                            <View android:id="@+id/bar3" android:layout_width="match_parent" android:layout_height="4dp"
                                android:background="@drawable/bg_bar_fill" android:layout_gravity="bottom"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:gravity="center_horizontal">
                        <FrameLayout android:layout_width="12dp" android:layout_height="match_parent">
                            <View android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="@drawable/bg_bar_track"/>
                            <View android:id="@+id/bar4" android:layout_width="match_parent" android:layout_height="4dp"
                                android:background="@drawable/bg_bar_fill" android:layout_gravity="bottom"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:gravity="center_horizontal">
                        <FrameLayout android:layout_width="12dp" android:layout_height="match_parent">
                            <View android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="@drawable/bg_bar_track"/>
                            <View android:id="@+id/bar5" android:layout_width="match_parent" android:layout_height="4dp"
                                android:background="@drawable/bg_bar_fill" android:layout_gravity="bottom"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:gravity="center_horizontal">
                        <FrameLayout android:layout_width="12dp" android:layout_height="match_parent">
                            <View android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="@drawable/bg_bar_track"/>
                            <View android:id="@+id/bar6" android:layout_width="match_parent" android:layout_height="4dp"
                                android:background="@drawable/bg_bar_fill" android:layout_gravity="bottom"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="1" android:gravity="center_horizontal">
                        <FrameLayout android:layout_width="12dp" android:layout_height="match_parent">
                            <View android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="@drawable/bg_bar_track"/>
                            <View android:id="@+id/bar7" android:layout_width="match_parent" android:layout_height="4dp"
                                android:background="@drawable/bg_bar_fill" android:layout_gravity="bottom"/>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="@drawable/bg_nav_bar"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.4"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Ana Sayfa"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_stats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_stats"
                android:contentDescription="İstatistikler"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.4"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_history"
                android:contentDescription="Geçmiş"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.4"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_profile"
                android:contentDescription="Profil"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>