<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#1B1F5E">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textSize="22sp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:layout_centerVertical="true"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Artikeller"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:layout_centerInParent="true"/>

            <TextView
                android:id="@+id/tv_art_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SORU 1/5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:background="@drawable/bg_kart_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginBottom="16dp"
            android:max="5"
            android:progress="0"
            android:progressTint="#FFD700"
            android:progressBackgroundTint="#2a3580"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <LinearLayout
            android:id="@+id/card_artikel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="36dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_german_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Haus"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="#1a2d6e"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tv_turkish_meaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ev"
                android:textSize="16sp"
                android:textColor="#8899cc"
                android:layout_marginTop="10dp"
                android:gravity="center"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/btn_der"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="DER"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B1F5E"
                android:gravity="center"
                android:background="@drawable/bg_button_purple"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btn_die"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="DIE"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B1F5E"
                android:gravity="center"
                android:background="@drawable/bg_button_purple"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btn_das"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="DAS"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B1F5E"
                android:gravity="center"
                android:background="@drawable/bg_button_purple"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:background="@drawable/bg_nav_bar"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:alpha="0.4"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="Ana Sayfa"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_stats"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:alpha="0.4"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_stats"
                    android:contentDescription="İstatistikler"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_history"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:alpha="0.4"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_history"
                    android:contentDescription="Geçmiş"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_profile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity ="center"
                android:alpha="0.4"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src= "@drawable/ic_profile"
                    android:contentDescription ="Profil"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_ai_feedback"
        android:layout_width ="match_parent"
        android:layout_height ="match_parent"
        android:orientation = "vertical"
        android:gravity="bottom"
        android:background="#E01B1F5E"
        android:visibility ="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_ai_feedback_card"
            android:paddingStart="20dp"
            android:paddingEnd = "20dp"
            android:paddingTop = "24dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background = "@drawable/bg_ai_icon"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_ai_sparkle"
                        android:contentDescription="AI"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hata Analizi"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1B1F5E"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Dil Mentörü"
                        android:textSize="12sp"
                        android:textColor="#8899cc"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/btn_ai_close"
                    android:layout_width= "34dp"
                    android:layout_height="34dp"
                    android:text="×"
                    android:textSize="22sp"
                    android:textColor="#8899cc"
                    android:gravity = "center"
                    android:background="@drawable/bg_ai_close_btn"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_ai_answer_wrong"
                    android:padding="12dp"
                    android:layout_marginEnd="5dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SENİN CEVABIN"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#C0445A"
                        android:letterSpacing="0.07"/>
                    <TextView
                        android:id="@+id/tv_ai_user_answer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1B1F5E"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height = "wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_ai_answer_correct"
                    android:padding ="12dp"
                    android:layout_marginStart="5dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOĞRU CEVAP"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#2E8A57"
                        android:letterSpacing="0.07"/>
                    <TextView
                        android:id="@+id/tv_ai_correct_answer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1B1F5E"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_ai_explain"
                android:padding="14dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Neden doğru cevap?"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#5B3A8A"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_ai_feedback_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analiz ediliyor…"
                    android:textSize="13sp"
                    android:textColor="#8899cc"/>

                <TextView
                    android:id="@+id/tv_ai_feedback_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#3d2d6e"
                    android:lineSpacingMultiplier="1.65"
                    android:visibility="gone"/>
            </LinearLayout>

            <TextView
                android:id="@+id/btn_ai_understood"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Anladım, Tekrarla"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_ai_btn"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_summary"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD1B1F5E"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oturum Tamamlandı!"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2D1B69"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_light"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tv_correct_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DOĞRU"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:textColor="#8899cc"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_light"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_wrong_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#C0392B"/>

                    <TextView
                        android:layout_width = "wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YANLIŞ"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:textColor="#8899cc"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_xp_badge"
                android:gravity="center"
                android:padding="14dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+"
                    android:textSize= "20sp"
                    android:textStyle="bold"
                    android:textColor="#1B1F5E"/>

                <TextView
                    android:id="@+id/tv_xp_earned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor = "#1B1F5E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" XP"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1B1F5E"/>
            </LinearLayout>

            <TextView
                android:id="@+id/btn_finish"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Ana Sayfaya Dön"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1B1F5E"
                android:gravity="center"
                android:background="@drawable/bg_button_purple"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>